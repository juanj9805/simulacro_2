@model IEnumerable<Treatment>

<div class="row">
    <a class="btn btn-success mb-3" asp-controller="Treatment" asp-action="Create">Create</a>
    <div class="col-12">
        <table class="table table-striped">
            <thead>
                <th>ID</th>
                <th>CONSULTATION</th>
                <th>PET</th>
                <th>DESCRIPTION</th>
                <th>CREATED AT</th>
                <th class="text-end">Actions</th>
            </thead>
            <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Id</td>
                    <td>@t.Consultation?.Reason</td>
                    <td>@t.Consultation?.Pet?.Name</td>
                    <td>@t.Description</td>
                    <td>@t.CreateAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a class="btn btn-outline-warning" asp-controller="Treatment" asp-action="Update" asp-route-id="@t.Id">Edit</a>
                        <form asp-controller="Treatment" asp-action="Delete" asp-route-id="@t.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
