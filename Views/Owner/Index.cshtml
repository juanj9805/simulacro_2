@model IEnumerable<Owner>

<div class="row">
    <a class="btn btn-success" asp-controller="Owner" asp-action="Create">Create</a>
    <div class="col-12">
        <table class="table table-striped">
            <thead>
            <th>ID</th>
            <th>NAME</th>
            <th>PHONE</th>
            <th class="text-end">Actions</th>
            </thead>
            <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.Id</td>
                    <td>@o.Name</td>
                    <td>@o.Phone</td>
                    <td class="text-end">
                        <a class="btn btn-outline-warning" asp-controller="Owner" asp-action="Index">Edit</a>
                        <a class="btn btn-outline-danger" asp-controller="Owner" asp-action="Index">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>