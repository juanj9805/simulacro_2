@model IEnumerable<Consultation>

<div class="row">
    <a class="btn btn-success mb-3" asp-controller="Consultation" asp-action="Create">Create</a>
    <div class="col-12">
        <table class="table table-striped">
            <thead>
                <th>ID</th>
                <th>REASON</th>
                <th>PET</th>
                <th>VETERINARY</th>
                <th>DATE START</th>
                <th>DATE END</th>
                <th>STATUS</th>
                <th class="text-end">Actions</th>
            </thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Id</td>
                    <td>@c.Reason</td>
                    <td>@c.Pet?.Name</td>
                    <td>@c.Veterinary?.Name</td>
                    <td>@c.DateStart.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@c.DateEnd.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@c.Status</td>
                    <td class="text-end">
                        <a class="btn btn-outline-warning" asp-controller="Consultation" asp-action="Update" asp-route-id="@c.Id">Edit</a>
                        <form asp-controller="Consultation" asp-action="Delete" asp-route-id="@c.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
