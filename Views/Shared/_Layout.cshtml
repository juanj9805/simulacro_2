<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VetCare</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/simulacro.styles.css" asp-append-version="true" />
    <style>
        :root {
            --sidebar-w: 256px;
            --sidebar-bg: #1a1f2e;
            --sidebar-border: rgba(255, 255, 255, 0.06);
            --sidebar-muted: #8892a4;
            --accent: #00c896;
            --accent-dim: rgba(0, 200, 150, 0.12);
            --accent-border: rgba(0, 200, 150, 0.28);
            --accent-2: #3b82f6;
            --header-h: 60px;
            --page-bg: #eef0f6;
            --card: #ffffff;
            --border: #e2e8f0;
            --text: #1a1f2e;
            --muted: #64748b;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.04);
            --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; }

        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
            background: var(--page-bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* ─── SIDEBAR ─────────────────────────────────── */
        .vc-sidebar {
            position: fixed;
            inset: 0 auto 0 0;
            width: var(--sidebar-w);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 200;
        }

        .vc-sidebar::after {
            content: '';
            position: absolute;
            top: 0; right: 0;
            width: 1px; height: 100%;
            background: var(--sidebar-border);
        }

        /* top gradient stripe */
        .vc-sidebar::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--accent), var(--accent-2));
            z-index: 1;
        }

        /* Brand */
        .vc-brand {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 22px 20px 18px;
            border-bottom: 1px solid var(--sidebar-border);
        }

        .vc-brand-logo {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            box-shadow: 0 4px 10px rgba(0,200,150,0.35);
        }

        .vc-brand-text { line-height: 1; }

        .vc-brand-name {
            font-size: 1.05rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.3px;
        }

        .vc-brand-tag {
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--accent);
            margin-top: 3px;
            display: block;
        }

        /* Nav */
        .vc-nav {
            flex: 1;
            padding: 12px 10px;
            overflow-y: auto;
        }

        .vc-nav::-webkit-scrollbar { width: 3px; }
        .vc-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 2px; }

        .vc-nav-group-label {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: rgba(136,146,164,0.45);
            padding: 18px 10px 6px;
            display: block;
        }

        .vc-nav-group-label:first-child { padding-top: 4px; }

        .vc-nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 10px;
            border-radius: 7px;
            color: var(--sidebar-muted);
            text-decoration: none;
            font-size: 0.845rem;
            font-weight: 500;
            transition: color 0.15s, background 0.15s;
            position: relative;
            margin-bottom: 1px;
        }

        .vc-nav-link:hover {
            color: #fff;
            background: rgba(255,255,255,0.06);
            text-decoration: none;
        }

        .vc-nav-link.active {
            color: var(--accent);
            background: var(--accent-dim);
        }

        .vc-nav-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 50%;
            transform: translateY(-50%);
            width: 3px; height: 18px;
            background: var(--accent);
            border-radius: 0 2px 2px 0;
        }

        .vc-nav-link svg {
            width: 16px; height: 16px;
            flex-shrink: 0;
            opacity: 0.65;
            transition: opacity 0.15s;
        }

        .vc-nav-link:hover svg,
        .vc-nav-link.active svg { opacity: 1; }

        /* Sidebar footer */
        .vc-sidebar-foot {
            padding: 14px 20px;
            border-top: 1px solid var(--sidebar-border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .vc-avatar {
            width: 30px; height: 30px;
            background: linear-gradient(135deg, #3b82f6, #6366f1);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.65rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .vc-sidebar-foot-info { line-height: 1.3; }

        .vc-sidebar-foot-name {
            font-size: 0.78rem;
            font-weight: 600;
            color: #fff;
            display: block;
        }

        .vc-sidebar-foot-role {
            font-size: 0.67rem;
            color: var(--sidebar-muted);
        }

        /* ─── MAIN SHELL ──────────────────────────────── */
        .vc-shell {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top header */
        .vc-header {
            position: sticky;
            top: 0;
            height: var(--header-h);
            background: var(--card);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 28px;
            gap: 14px;
            z-index: 100;
            box-shadow: var(--shadow-sm);
        }

        .vc-header-divider {
            width: 1px; height: 22px;
            background: var(--border);
            flex-shrink: 0;
        }

        .vc-header-page {
            flex: 1;
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text);
        }

        .vc-header-crumb {
            font-size: 0.72rem;
            color: var(--muted);
            font-weight: 400;
            display: block;
            line-height: 1;
            margin-top: 2px;
        }

        .vc-status-dot {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--accent);
            background: var(--accent-dim);
            border: 1px solid var(--accent-border);
            padding: 4px 11px;
            border-radius: 20px;
            letter-spacing: 0.3px;
        }

        .vc-status-dot::before {
            content: '';
            width: 6px; height: 6px;
            background: var(--accent);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        /* Content */
        .vc-content {
            flex: 1;
            padding: 26px 28px;
        }

        .vc-card {
            background: var(--card);
            border-radius: 10px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
            padding: 26px 28px;
        }

        /* Footer */
        .vc-footer {
            padding: 13px 28px;
            background: var(--card);
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.73rem;
            color: var(--muted);
        }

        .vc-footer a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
        }

        .vc-footer a:hover { text-decoration: underline; }
    </style>
</head>
<body>

    <!-- ═══ SIDEBAR ═══════════════════════════════════════════ -->
    <aside class="vc-sidebar">

        <div class="vc-brand">
            <div class="vc-brand-logo">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                    <path d="M4.5 10.5C5.88 10.5 7 9.38 7 8S5.88 5.5 4.5 5.5 2 6.62 2 8s1.12 2.5 2.5 2.5zm15 0C20.88 10.5 22 9.38 22 8s-1.12-2.5-2.5-2.5S17 6.62 17 8s1.12 2.5 2.5 2.5zM8.5 7C9.88 7 11 5.88 11 4.5S9.88 2 8.5 2 6 3.12 6 4.5 7.12 7 8.5 7zm7 0C16.88 7 18 5.88 18 4.5S16.88 2 15.5 2 13 3.12 13 4.5s1.12 2.5 2.5 2.5zM12 10c-3.31 0-6 2.69-6 6v4h12v-4c0-3.31-2.69-6-6-6z"/>
                </svg>
            </div>
            <div class="vc-brand-text">
                <div class="vc-brand-name">VetCare</div>
                <span class="vc-brand-tag">Management</span>
            </div>
        </div>

        <nav class="vc-nav">
            <span class="vc-nav-group-label">General</span>

            <a class="vc-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                </svg>
                Home
            </a>

            <span class="vc-nav-group-label">Clinic</span>

            <a class="vc-nav-link" asp-area="" asp-controller="Medicine" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M6.5 10h-2v5h2v-5zm4 0h-2v5h2v-5zm8.5 7H4v1.5c0 .83.67 1.5 1.5 1.5h13c.83 0 1.5-.67 1.5-1.5V17zm-4-7h-2v5h2v-5zM11.24 2L4 5v2h16V5l-8.76-3z"/>
                </svg>
                Medicines
            </a>

            <a class="vc-nav-link" asp-area="" asp-controller="Veterinary" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 8h-1V3H6v5H5c-1.66 0-3 1.34-3 3v6h4v4h12v-4h4v-6c0-1.66-1.34-3-3-3zM8 5h8v3H8V5zm8 14H8v-4h8v4zm2-4v-2H6v2H4v-4c0-.55.45-1 1-1h14c.55 0 1 .45 1 1v4h-2z"/>
                </svg>
                Veterinaries
            </a>

            <a class="vc-nav-link" asp-area="" asp-controller="Owner" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                </svg>
                Owners
            </a>
            
            <a class="vc-nav-link" asp-area="" asp-controller="Pet" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                </svg>
                Pets
            </a>

            <a class="vc-nav-link" asp-area="" asp-controller="Report" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14H7v-2h5v2zm5-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                </svg>
                Reports
            </a>

            <span class="vc-nav-group-label">Medical</span>

            <a class="vc-nav-link" asp-area="" asp-controller="Consultation" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/>
                </svg>
                Consultations
            </a>

            <a class="vc-nav-link" asp-area="" asp-controller="Treatment" asp-action="Index">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20 6h-2.18c.07-.44.18-.88.18-1.38C18 2.51 15.48 0 12.38 0c-1.5 0-2.91.59-3.94 1.65L6 4 3.56 1.56A1.996 1.996 0 0 0 .71 4.41L4 7.71V20c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-1h2c1.1 0 2-.9 2-2v-9c0-1.1-.9-2-2-2z"/>
                </svg>
                Treatments
            </a>
        </nav>

        <div class="vc-sidebar-foot">
            <div class="vc-avatar">VC</div>
            <div class="vc-sidebar-foot-info">
                <span class="vc-sidebar-foot-name">VetCare Clinic</span>
                <span class="vc-sidebar-foot-role">System v1.0</span>
            </div>
        </div>

    </aside>

    <!-- ═══ SHELL ══════════════════════════════════════════════ -->
    <div class="vc-shell">

        <header class="vc-header">
            <div class="vc-header-page">
                @ViewData["Title"]
                <span class="vc-header-crumb">VetCare Management System</span>
            </div>
            <div class="vc-header-divider"></div>
            <span class="vc-status-dot">Live</span>
        </header>

        <div class="vc-content">
            <div class="vc-card">
                @RenderBody()
            </div>
        </div>

        <footer class="vc-footer">
            <span>&copy; 2026 VetCare Management System</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var path = window.location.pathname.toLowerCase();
            document.querySelectorAll('.vc-nav-link').forEach(function (a) {
                var href = (a.getAttribute('href') || '').toLowerCase();
                if (!href) return;
                var isHome = href === '/' || href.endsWith('/home/index');
                if (isHome) {
                    if (path === '/' || path === '/home' || path === '/home/index') a.classList.add('active');
                } else if (path.startsWith(href)) {
                    a.classList.add('active');
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
    