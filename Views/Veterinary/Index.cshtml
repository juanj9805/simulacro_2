@model IEnumerable<Veterinary>

<div class="row">
    <a class="btn btn-success mb-3" asp-controller="Veterinary" asp-action="Create">Create</a>
    <div class="col-12">
        <table class="table table-striped">
            <thead>
                <th>ID</th>
                <th>NAME</th>
                <th>SPECIALITY</th>
                <th class="text-end">Actions</th>
            </thead>
            <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.Id</td>
                    <td>@v.Name</td>
                    <td>@v.Speciality</td>
                    <td class="text-end">
                        <a class="btn btn-outline-warning" asp-controller="Veterinary" asp-action="Update" asp-route-id="@v.Id">Edit</a>
                        <form asp-controller="Veterinary" asp-action="Delete" asp-route-id="@v.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
